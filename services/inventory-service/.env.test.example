# Template das variaveis de ambiente para TESTES do inventory-service.
# Copie para .env.test e preencha. O .env.test e ignorado pelo git; este
# .example e versionado para documentar o que o ambiente de teste (e o CI) precisa.

# Banco de teste ISOLADO — deve conter 'test' no nome (salvaguarda do setup.ts).
DATABASE_URL=postgresql://postgres:senha@127.0.0.1:5432/inventory_test_db

INVENTORY_PORT=3004

# Segredo para assinar/verificar JWT nos testes de autorizacao. Valor de teste,
# NAO usar o de producao. Sem isto, os testes de auth falham.
JWT_SECRET=coloque-um-segredo-de-teste-aqui
